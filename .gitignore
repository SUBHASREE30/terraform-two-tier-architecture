# Terraform State Files - NEVER commit these (contain sensitive data)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform Variables with secrets - NEVER commit
*.tfvars
*.tfvars.json

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# SSH Keys - NEVER commit private keys
*.pem
*.key
id_rsa
id_rsa.pub

# OS Files
.DS_Store
Thumbs.db

# IDE Files
.vscode/
.idea/
*.swp
*.swo

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
